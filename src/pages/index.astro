---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';

const pageTitle = 'You Best Deal — Lifetime Deals & Software Coupons';
const pageDescription = 'Never pay full price again. Discover the best AppSumo lifetime deals (LTDs) and SaaS coupons.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://youbestdeal.com/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <Hero title="Unlock Exclusive Lifetime Software Deals" subtitle="Save up to 90% on premium SaaS with our curated LTDs." />

  <section class="container mx-auto px-6 py-8 animate-fade-in-up" style="animation-delay: 0.2s;">
    <h2 class="text-xl md:text-2xl font-bold mb-10 text-white tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-6 bg-primary-500 rounded-full"></span>
      Popular Categories
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6 auto-rows-fr">
      <Card title="LTDs" description="Lifetime Deals ending soon" href="/en/categories/c1/" tag="Trending" featured={true} />
      <Card title="Marketing" description="Discounted SEO Tools" href="/en/categories/c2/" tag="New" />
      <Card title="Design" description="UI/UX Tools on Sale" href="/en/categories/c3/" />
      <Card title="Hosting" description="Cheap Web Hosting" href="/en/categories/c4/" />
    </div>
  </section>

  <section class="container mx-auto px-6 py-16 animate-fade-in-up" style="animation-delay: 0.4s;">
    <h2 class="text-xl md:text-2xl font-bold mb-10 text-white tracking-tight flex items-center gap-3">
      <span class="w-1.5 h-6 bg-purple-500 rounded-full"></span>
      Latest Updates
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <Card title="SurferSEO 90% Off Coupon" description="Read our latest in-depth review and analysis for 2026." href="/en/reviews/1/" rating={4.9} price="Verified" />
      <Card title="Canva Pro Lifetime Deal" description="A comprehensive breakdown of features, pricing, and pros/cons." href="/en/reviews/2/" rating={4.7} price="Top Choice" />
      <Card title="Hostinger Black Friday" description="Everything you need to know before making a decision." href="/en/reviews/3/" rating={4.5} price="Updated" />
    </div>
  </section>
</BaseLayout>
