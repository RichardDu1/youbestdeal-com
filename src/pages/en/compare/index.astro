---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';

const title = 'Compare AI Tools — Find the AI For That (2026)';
const description = 'Side-by-side AI tool comparisons. Same prompts, same tasks — see which tool performs best.';
---

<BaseLayout title={title} description={description}>
  <Breadcrumb />
  <section class="container py-16">
    <h1 class="text-3xl font-bold mb-8">AI Tool Comparisons</h1>
    <p class="text-muted mb-10 max-w-2xl">We test AI tools on the same tasks so you can see real differences. No marketing fluff — just results.</p>
    <div class="space-y-4 max-w-3xl">
      <a href="/en/compare/claude-vs-chatgpt/" class="block p-5 bg-white border rounded-lg hover:border-primary/30 transition-colors">
        <h3 class="font-semibold">Claude vs ChatGPT (2026)</h3>
        <p class="text-sm text-muted mt-1">Which AI assistant is better for writing, coding, and analysis?</p>
      </a>
    </div>
  </section>
</BaseLayout>
