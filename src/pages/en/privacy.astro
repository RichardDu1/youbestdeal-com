---
// Privacy Policy page
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const title = 'Privacy Policy — Find the AI For That (2026)';
const description = 'Our privacy policy: what data we collect, how we use it, and your rights. GDPR compliant.';
---

<BaseLayout title={title} description={description} noindex={true}>
  <Breadcrumb />
  <section class="container py-16 max-w-3xl">
    <h1 class="text-3xl font-bold mb-6">Privacy Policy</h1>
    <div class="prose prose-lg max-w-none text-muted space-y-4">
      <p><strong>Last updated:</strong> June 2026</p>
      <h2 class="text-xl font-bold text-text">1. Information We Collect</h2>
      <p>We use Umami Analytics, a privacy-friendly analytics tool that does not use cookies and does not collect personal data. We do not track you across sites.</p>
      <h2 class="text-xl font-bold text-text">2. Affiliate Disclosure</h2>
      <p>Some links on this site are affiliate links. If you click and make a purchase, we may earn a commission at no extra cost to you. All affiliate links are marked with <code>rel="sponsored nofollow"</code>.</p>
      <h2 class="text-xl font-bold text-text">3. Third-Party Services</h2>
      <p>We may use third-party services (such as Google AdSense) that set cookies for advertising purposes. You can opt out via your browser settings.</p>
      <h2 class="text-xl font-bold text-text">4. Your Rights</h2>
      <p>You have the right to access, correct, or delete any personal data we may hold. Contact us at hello@findtheaiforthat.com.</p>
      <h2 class="text-xl font-bold text-text">5. Contact</h2>
      <p>For privacy-related inquiries: hello@findtheaiforthat.com</p>
    </div>
  </section>
</BaseLayout>
