---
// About page
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const title = 'About Find the AI For That (2026)';
const description = 'We help you discover, compare, and choose the best AI tools for every task. Independent reviews, no BS.';
---

<BaseLayout
  title={title}
  description={description}
  schema={{ type: 'Organization', data: {} }}
>
  <Breadcrumb />
  <section class="container py-16 max-w-3xl">
    <h1 class="text-3xl font-bold mb-6">About Find the AI For That</h1>
    <div class="prose prose-lg max-w-none text-muted space-y-4">
      <p>We're on a mission to help everyone — from solo creators to enterprise teams — find the right AI tool for the job. The AI landscape changes weekly, and keeping up is exhausting. We do the research so you don't have to.</p>
      <p>Every tool on this site is independently tested. We never accept payment for positive reviews. Affiliate links are clearly marked, and we disclose them transparently.</p>
      <h2 class="text-xl font-bold text-text mt-8 mb-3">Our Process</h2>
      <ol class="list-decimal list-inside space-y-2">
        <li>Hands-on testing — we use every tool we review</li>
        <li>Side-by-side comparisons — same prompts, same tasks</li>
        <li>Regular updates — tools change, so do our reviews</li>
        <li>Community feedback — your experience matters</li>
      </ol>
    </div>
  </section>
</BaseLayout>
