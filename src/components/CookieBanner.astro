---
// CookieBanner.astro
---
<div id="cookie-banner" class="fixed bottom-0 left-0 w-full z-[100] transform translate-y-full transition-transform duration-500 ease-in-out">
  <div class="bg-dark/80 backdrop-blur-xl border-t border-white/10 p-4 md:p-6 shadow-[0_-10px_40px_rgba(0,0,0,0.5)]">
    <div class="container mx-auto max-w-6xl flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-sm text-gray-300 flex-1">
        <strong class="text-white block mb-1 text-base">Privacy & Cookies Policy</strong>
        We use cookies and similar technologies to enhance your browsing experience, serve personalized content, and analyze our traffic. By clicking "Accept All", you consent to our use of cookies. Read our <a href="/en/privacy/" class="text-primary-400 hover:text-primary-300 underline underline-offset-2">Privacy Policy</a> for more details.
      </div>
      <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto shrink-0">
        <button id="cookie-decline" class="px-6 py-2.5 rounded-xl border border-white/10 text-white font-medium hover:bg-white/5 transition-colors text-sm">
          Essential Only
        </button>
        <button id="cookie-accept" class="px-6 py-2.5 rounded-xl bg-primary-500 hover:bg-primary-400 text-white font-bold shadow-[0_0_15px_rgba(var(--color-primary-500),0.4)] transition-all text-sm">
          Accept All
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const banner = document.getElementById('cookie-banner');
    const btnAccept = document.getElementById('cookie-accept');
    const btnDecline = document.getElementById('cookie-decline');
    
    // Check local storage
    const consent = localStorage.getItem('cookie-consent');
    if (!consent) {
      // Small delay for animation
      setTimeout(() => {
        banner?.classList.remove('translate-y-full');
      }, 500);
    }

    const hideBanner = (value) => {
      localStorage.setItem('cookie-consent', value);
      banner?.classList.add('translate-y-full');
    };

    btnAccept?.addEventListener('click', () => hideBanner('accepted'));
    btnDecline?.addEventListener('click', () => hideBanner('declined'));
  });
</script>
