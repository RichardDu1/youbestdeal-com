        <h4 class="text-white font-semibold mb-3">Resources</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/en/blog/" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/en/compare/" class="hover:text-white transition-colors">Compare Tools</a></li>
          <li><a href="/en/latest/" class="hover:text-white transition-colors">Latest Tools</a></li>
          <li><a href="/en/newsletter/" class="hover:text-white transition-colors">Newsletter</a></li>
