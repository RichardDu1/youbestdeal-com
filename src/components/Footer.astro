    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div>
        <h3 class="text-white font-bold text-lg mb-3">You Best Deal</h3>
        <p class="text-sm text-gray-400 leading-relaxed">
          Find the best deals online. Reviews, comparisons, and savings tips.
        </p>
