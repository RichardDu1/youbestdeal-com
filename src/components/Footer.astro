        <h4 class="text-white font-semibold mb-3">Company</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/en/about/" class="hover:text-white transition-colors">About</a></li>
          <li><a href="/en/contact/" class="hover:text-white transition-colors">Contact</a></li>
          <li><a href="/en/privacy/" class="hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/en/terms/" class="hover:text-white transition-colors">Terms of Use</a></li>
