          <li><a href="/en/categories/image/" class="hover:text-white transition-colors">AI Image</a></li>
          <li><a href="/en/categories/coding/" class="hover:text-white transition-colors">AI Coding</a></li>
          <li><a href="/en/categories/productivity/" class="hover:text-white transition-colors">AI Productivity</a></li>
